# ---------- Postgres ----------
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=55432
POSTGRES_USER=datamind
POSTGRES_PASSWORD=datamind
POSTGRES_DB=datamind
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=60
POSTGRES_POOL_RECYCLE=3600

# ---------- Oracle ----------
ORACLE_IMAGE=gvenzl/oracle-xe:21-slim
ORACLE_SERVICE_NAME=FREEPDB1
ORACLE_DATABASE=datamind
ORACLE_PASSWORD=datamind
ORACLE_HOST=oracle
ORACLE_PORT=51521
ORACLE_APP_USER=datamind
ORACLE_APP_USER_PASSWORD=datamind
ORACLE_POOL_SIZE=5
ORACLE_MAX_OVERFLOW=10
ORACLE_POOL_TIMEOUT=60
ORACLE_POOL_RECYCLE=3600
ORACLE_EM_PORT=55500


# ---------- Datamind ----------
DATAMIND_IMAGE=dataminddev/datamind:latest
DATAMIND_CONFIG_PATH=/app/config/config.yaml
DATAMIND_PORT=3000
DATAMIND_LOG_NAME=DatamindLogger
DATAMIND_LOG_FILE=/app/logs/Datamind.log
DATAMIND_LOG_LEVEL=INFO
DATAMIND_LOG_MAX_BYTES=10485760
DATAMIND_LOG_BACKUP_COUNT=5
DATAMIND_LOG_USE_CONCURRENT=true

# ---------- 通用 ----------
TZ=Asia/Shanghai
