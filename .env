# 应用配置
DATAMIND_APP_NAME=Datamind
DATAMIND_VERSION=1.0.0
DATAMIND_ENV=development
DATAMIND_DEBUG=false

# 日志设置
DATAMIND_LOG_NAME=Datamind
DATAMIND_LOG_LEVEL=INFO
DATAMIND_LOG_DIR=logs
DATAMIND_LOG_FORMAT=both
DATAMIND_LOG_FILE=app.log
DATAMIND_ERROR_LOG_FILE=error.log
DATAMIND_ACCESS_LOG_FILE=access.log
DATAMIND_AUDIT_LOG_FILE=audit.log
DATAMIND_PERFORMANCE_LOG_FILE=performance.log
DATAMIND_LOG_ENCODING=utf-8
DATAMIND_LOG_TIMEZONE=CST
DATAMIND_FILE_NAME_TIMESTAMP=false
DATAMIND_LOG_ROTATION_AT_TIME=23:59
DATAMIND_LOG_ROTATION_UTC=false
DATAMIND_LOG_RETENTION_DAYS=90
DATAMIND_LOG_ARCHIVE_PATH=archive
DATAMIND_LOG_MAX_BYTES=104857600
DATAMIND_LOG_BACKUP_COUNT=30
DATAMIND_LOG_ROTATION_WHEN=MIDNIGHT
DATAMIND_LOG_ROTATION_INTERVAL=1
DATAMIND_LOG_USE_CONCURRENT=true
DATAMIND_LOG_CONSOLE=false
DATAMIND_LOG_ARCHIVE=true
DATAMIND_LOG_FORMATTER_DEBUG=false
DATAMIND_LOG_MANAGER_DEBUG=false
DATAMIND_LOG_HANDLER_DEBUG=false
DATAMIND_LOG_FILTER_DEBUG=false
DATAMIND_LOG_CONTEXT_DEBUG=false
DATAMIND_LOG_CLEANUP_DEBUG=false