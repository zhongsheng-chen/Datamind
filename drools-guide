package com.myspace.test;

rule "Apply Tall Order Discount"
dialect "mvel"
no-loop true
when
    $sc : ShoppingCart( $tp : totalPrice >= 10000.0 )
then
    modify( $sc ) {
        setTotalPrice( $tp * 0.5 )
    }
end



