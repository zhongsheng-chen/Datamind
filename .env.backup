# 基本配置
DATAMIND_APP_NAME=datamind
DATAMIND_VERSION=1.0.0
DATAMIND_ENV=development

# 数据库配置
DATAMIND_DATABASE_URL=postgresql://datamind:datamind@localhost:5432/datamind

# 日志配置
DATAMIND_LOG_NAME=datamind
DATAMIND_LOG_LEVEL=DEBUG
DATAMIND_LOG_DIR=logs
DATAMIND_LOG_FILE=datamind.log
DATAMIND_LOG_ENCODING=utf-8
DATAMIND_LOG_FORMAT=text
DATAMIND_LOG_TIMEZONE=Asia/Shanghai
DATAMIND_LOG_TIME_OFFSET_HOURS=0
DATAMIND_LOG_FILE_NAME_TIMESTAMP=true
DATAMIND_LOG_FILE_NAME_DATE_FORMAT=%Y%m%d
DATAMIND_LOG_ROTATION_STRATEGY=time
DATAMIND_LOG_ROTATION_WHEN=MIDNIGHT
DATAMIND_LOG_ROTATION_INTERVAL=1
DATAMIND_LOG_ROTATION_AT_TIME=23:59
DATAMIND_LOG_ROTATION_UTC=false
DATAMIND_LOG_MAX_BYTES=104857600
DATAMIND_LOG_BACKUP_COUNT=30
DATAMIND_LOG_RETENTION_DAYS=90
DATAMIND_LOG_ARCHIVE_ENABLED=true
DATAMIND_LOG_ARCHIVE_PATH=archive
DATAMIND_LOG_ARCHIVE_COMPRESSION=gz
DATAMIND_LOG_ARCHIVE_NAME_FORMAT=%Y%m%d_%H%M%S
DATAMIND_LOG_CLEANUP_AT_TIME=03:00
DATAMIND_LOG_USE_CONCURRENT=true
DATAMIND_LOG_CONCURRENT_LOCK_DIR=/tmp/datamind-logs
DATAMIND_LOG_USE_ASYNC=false
DATAMIND_LOG_ASYNC_QUEUE_SIZE=10000
DATAMIND_LOG_SAMPLING_RATE=1.0
DATAMIND_LOG_SAMPLING_INTERVAL=0
DATAMIND_LOG_MASK_SENSITIVE=true
DATAMIND_LOG_MASK_CHAR=*
DATAMIND_LOG_CONSOLE_OUTPUT=true
DATAMIND_LOG_CONSOLE_LEVEL=INFO
DATAMIND_LOG_ENABLE_REMOTE=false
DATAMIND_LOG_REMOTE_TIMEOUT=5
DATAMIND_LOG_REMOTE_BATCH_SIZE=100
DATAMIND_LOG_VALIDATE_ON_STARTUP=true